   "source": [
    "alpha_values = [0.01, 0.05, 0.1, 0.3, 0.5, 0.7]\n",
    "P_fixed = 6000\n",
    "\n",
    "train_accs = []\n",
    "test_accs  = []\n",
    "\n",
    "rng = np.random.default_rng(42)\n",
    "\n",
    "for a in alpha_values:\n",
    "    w = np.zeros(Xtr.shape[1])\n",
    "    for _ in range(P_fixed):\n",
    "        p_tr = sigmoid(Xtr @ w)\n",
    "        grad = (Xtr.T @ (ytr - p_tr)) / Xtr.shape[0]\n",
    "        w = w + a * grad\n",
    "    \n",
    "    acc_tr = np.mean((sigmoid(Xtr @ w) >= 0.5).astype(int) == ytr)\n",
    "    train_accs.append(acc_tr)\n",
    "    \n",
    "    acc_te = np.mean((sigmoid(X_test_plus_val @ w) >= 0.5).astype(int) == y_test_plus_val.ravel())\n",
    "    test_accs.append(acc_te)\n",
    "\n",
    "plt.figure(figsize=(9, 5))\n",
    "plt.plot(alpha_values, train_accs, marker='o', label=\"Train Accuracy\")\n",
    "plt.plot(alpha_values, test_accs,  marker='s', label=\"Test+Val Accuracy\")\n",
    "plt.title(f\"Accuracy vs Learning Rate (α) | P = {P_fixed}\")\n",
    "plt.xlabel(\"Learning Rate (α)\")\n",
    "plt.ylabel(\"Accuracy\")\n",
    "plt.grid(True, linestyle=\"--\", alpha=0.35)\n",
    "plt.xticks(alpha_values)\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "alpha = 0.1\n",
    "max_iters = 10000\n",
    "\n",
    "train_acc = []\n",
    "test_acc = []\n",
    "iters = []\n",
    "\n",
    "\n",
    "w = np.zeros(X_train.shape[1], dtype=float)\n",
    "for i in range(1, max_iters+1):\n",
    "    p = sigmoid(X_train @ w)\n",
    "    grad = (X_train.T @ (y_train - p)) / y_train.size\n",
    "    w += alpha * grad\n",
    "\n",
    "    if i % 600 == 0:\n",
    "        pred_train = sigmoid(X_train @ w) >= 0.5\n",
    "        pred_test  = sigmoid(X_test_plus_val @ w) >= 0.5  \n",
    "        acc_train = np.mean(pred_train == y_train)\n",
    "        acc_test  = np.mean(pred_test == y_test_plus_val)\n",
    "\n",
    "        iters.append(i)\n",
    "        train_acc.append(acc_train)\n",
    "        test_acc.append(acc_test)\n",
    "\n",
    "plt.figure(figsize=(9,5))\n",
