   ],
   "source": [
    "# Convert training labels to 1D float array\n",
    "Xtr = X_train.astype(float)\n",
    "ytr = y_train.astype(float).ravel()\n",
    "N, D = Xtr.shape\n",
    "\n",
    "alpha = 0.1   # learning rate: how big each step is\n",
    "P = 6000      # number of training iterations\n",
    "w = np.zeros(D, dtype=float)   # start all weights at 0\n",
    "eps = 1e-12\n",
    "\n",
    "loss_hist = []\n",
    "acc_hist = []\n",
    "\n",
    "def sigmoid(z):   # squash any real number to a value between 0 and 1\n",
    "    z = np.clip(z, -40, 40)\n",
    "    return 1 / (1 + np.exp(-z))\n",
    "# choose a few iteration numbers to print progress\n",
    "sample_ts = sorted(set([0, P//20, P//10, P//8, P//6, P//4, P//2, 3*P//4, P]))\n",
    "print(f\"{'t':>6} | {'train_loss':>11} | {'train_acc':>9} | {'test_loss':>10} | {'test_acc':>8}\")\n",
    "print(\"-\"*60)\n",
    "\n",
    "for t in range(P+1):   # training loop: repeat P+1 times\n",
    "    \n",
    "     # forward pass on train: predictions with current weights\n",
    "\n",
    "    p = sigmoid(Xtr @ w)   # predicted probability for each sample\n",
    "    grad = (Xtr.T @ (ytr - p)) / N  # calculate gradient: tells us how to change weights to reduce error\n",
    "    w = w + (alpha * grad)  # update weights: move a small step in the direction of gradient\n",
    "\n",
    "    # measure how good the model is on training set\n",
    "    train_loss = -np.mean(ytr*np.log(p+eps) + (1-ytr)*np.log(1-p+eps))\n",
    "    train_acc  = np.mean((p >= 0.5).astype(int) == ytr)\n",
    "    \n",
    "    # check performance on test+validation set\n",
    "    p_te = sigmoid(X_test_plus_val @ w)\n",
    "    p_te = np.clip(p_te, eps, 1-eps)\n",
    "    test_loss = -np.mean(y_test_plus_val.ravel()*np.log(p_te) +\n",
    "                     (1-y_test_plus_val.ravel())*np.log(1-p_te))\n",
    "    test_acc = np.mean((p_te >= 0.5).astype(int) == y_test_plus_val.ravel())\n",
    "\n",
    "    if t in sample_ts:\n",
    "        print(f\"{t:6d} | {train_loss:11.6f} | {train_acc:9.3f} | {test_loss:10.6f} | {test_acc:8.4f}\")\n",
    "\n",
    "\n",
    "print(\"\\nFinal summary:\")\n",
    "print(f\"  Train loss    : {train_loss:.6f}\")\n",
    "print(f\"  Train acc     : {train_acc:.4f} ({train_acc*100:.2f}%)\")\n",
    "print(f\"  Test+Val loss : {test_loss:.6f}\")\n",
    "print(f\"  Test+Val acc  : {test_acc:.4f} ({test_acc*100:.2f}%)\")"
   ]
