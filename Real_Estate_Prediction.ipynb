   ],
   "source": [
    "# Convert test data to numbers\n",
    "Xte = X_test_plus_val.astype(float)\n",
    "yte = y_test_plus_val.astype(int).ravel()\n",
    "\n",
    "# Function to calculate loss, accuracy, and probabilities\n",
    "def metrics(X, y, w, eps=1e-12):\n",
    "    p = sigmoid(X @ w)\n",
    "    p = np.clip(p, eps, 1 - eps)\n",
    "    loss = -np.mean(y*np.log(p) + (1-y)*np.log(1-p))\n",
    "    acc  = np.mean((p >= 0.5).astype(int) == y)\n",
    "    return loss, acc, p\n",
    "\n",
    "# Function to build a 2x2 confusion matrix\n",
    "def confusion_matrix_2x2(y_true, y_pred_labels):\n",
    "    y_true = y_true.astype(int).ravel()  \n",
    "    y_pred = y_pred_labels.astype(int).ravel()\n",
    "    tn = np.sum((y_true == 0) & (y_pred == 0)) # true negatives\n",
    "    fp = np.sum((y_true == 0) & (y_pred == 1)) # false positives\n",
    "    fn = np.sum((y_true == 1) & (y_pred == 0)) # false negatives\n",
    "    tp = np.sum((y_true == 1) & (y_pred == 1)) # true positives\n",
    "    return np.array([[tn, fp],[fn, tp]], dtype=int)\n",
    "\n",
    "\n",
    "w = np.zeros(D, dtype=float)\n",
    "# Lists to save history of training and testing\n",
    "train_loss_hist, train_acc_hist = [], []\n",
    "test_loss_hist,  test_acc_hist  = [], []\n",
    "\n",
    "   # Save milestones for snapshots at start, middle, and end\n",
    "milestones = {0: \"w^(0) start\", P//2: f\"w^({P//2}) middle\", P: f\"w^({P}) final\"}\n",
    "cms_train, cms_test = {}, {} # store confusion matrices \n",
    "\n",
    "tr_loss, tr_acc, p_tr = metrics(Xtr, ytr, w, eps)\n",
    "te_loss, te_acc, p_te = metrics(Xte, yte, w, eps)\n",
    "train_loss_hist.append(tr_loss); train_acc_hist.append(tr_acc)\n",
    "test_loss_hist.append(te_loss);  test_acc_hist.append(te_acc)\n",
    "\n",
    "cms_train[0] = confusion_matrix_2x2(ytr, (p_tr >= 0.5).astype(int))\n",
    "cms_test[0]  = confusion_matrix_2x2(yte, (p_te >= 0.5).astype(int))\n",
    "\n",
    "\n",
    "# Training loop: update weights P times\n",
    "for t in range(1, P+1):\n",
    "    p_now = sigmoid(Xtr @ w)\n",
    "    grad  = (Xtr.T @ (ytr - p_now)) / N\n",
    "    w     = w + alpha * grad\n",
    "\n",
    "    tr_loss, tr_acc, p_tr = metrics(Xtr, ytr, w, eps)\n",
    "    te_loss, te_acc, p_te = metrics(Xte, yte, w, eps)\n",
    "\n",
    "    train_loss_hist.append(tr_loss); train_acc_hist.append(tr_acc)\n",
    "    test_loss_hist.append(te_loss);  test_acc_hist.append(te_acc)\n",
    "    \n",
    "    # if t is a milestone (0, middle, or final), save confusion matrix\n",
    "    if t in milestones:\n",
    "        cms_train[t] = confusion_matrix_2x2(ytr, (p_tr >= 0.5).astype(int))\n",
    "        cms_test[t]  = confusion_matrix_2x2(yte, (p_te >= 0.5).astype(int))\n",
    "\n",
    "    \n",
    "# Collect confusion matrices for start, middle, and end (train set)\n",
    "cm0   = cms_train[0]\n",
    "cmMid = cms_train[P//2]\n",
    "cmFin = cms_train[P]\n",
    "\n",
    "iters = np.arange(P+1)\n",
    "plt.figure()\n",
    "plt.plot(iters, train_loss_hist)\n",
    "plt.xlabel(\"t iteration\")\n",
    "plt.ylabel(\"loss\")\n",
    "plt.title(\"Training loss vs. iterations\")\n",
    "plt.grid(True); plt.tight_layout()\n",
    "\n",
    "plt.figure()\n",
    "plt.plot(iters, train_acc_hist)\n",
    "plt.xlabel(\" t iteration \")\n",
    "plt.ylabel(\"accuracy\")\n",
    "plt.title(\"Training accuracy vs. iterations\")\n",
    "plt.grid(True); plt.tight_layout()"
   ]
  },
