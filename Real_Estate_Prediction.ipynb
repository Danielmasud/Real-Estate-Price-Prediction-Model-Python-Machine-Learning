   "source": [
    "train_frac = 0.70  # we want 70% of the data for training\n",
    "train_idx = labels.groupby(labels, group_keys=False).sample(frac=train_frac, random_state=42).index # randomly choose 70% of the indexes (rows) for training, same ratio of A and B\n",
    "testval_idx = labels.index.difference(train_idx) # the rest of the rows (not in train) will be test+validation\n",
    "# make the training set: features and labels\n",
    "X_train = X[train_idx]\n",
    "y_train = y_np[train_idx]\n",
    "# make the test+validation set: features and labels\n",
    "X_test_plus_val = X[testval_idx]\n",
    "y_test_plus_val = y_np[testval_idx]\n",
    "\n",
    "assert set(train_idx).isdisjoint(set(testval_idx)) # check: no overlap between training and test sets\n",
    "assert len(train_idx) + len(testval_idx) == len(labels) # check: total rows = train + test\n",
    "\n",
    "n_total = len(labels)\n",
    "n_train = len(train_idx)\n",
    "n_testval = len(testval_idx)\n",
    "# calculate percentages\n",
    "train_pct = n_train / n_total * 100\n",
    "testval_pct = n_testval / n_total * 100\n",
    "\n",
    "print(f\"Chosen split: train= {int(train_frac*100)}% / test+val= {int((1-train_frac)*100)}%\")\n",
    "\n",
    "print(\"Train shape:\", X_train.shape, \" Test+Val shape:\", X_test_plus_val.shape)\n",
    "print(\"Train counts -> A:\", (y_train==0).sum(), \"B:\", (y_train==1).sum())\n",
    "print(\"Test+Val counts -> A:\", (y_test_plus_val==0).sum(), \"B:\", (y_test_plus_val==1).sum())\n"
   ]
